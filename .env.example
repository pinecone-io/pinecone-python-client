## Fill in real values and rename this file to .env before
## running integration tests on your machine.

## Your Pinecone API key. Picked up automatically by the integration tests.
PINECONE_API_KEY=''

## Optional: a second API key used by some maintenance/cleanup helpers
## in scripts/repl.py.
PINECONE_API_KEY_CI_TESTING=''

## Optional: extra HTTP headers attached to every request. Must be a JSON
## string (so it survives env-var round-tripping).
##
##   PINECONE_ADDITIONAL_HEADERS='{"x-my-trace-id": "abc-123"}'
PINECONE_ADDITIONAL_HEADERS=''
